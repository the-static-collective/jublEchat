# Supabase Client Credentials (required for production, falls back to local storage in sandbox/dev mode)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-Side Supabase Service Key (critical for bypassing RLS on server-bound transactions and RPC executions)
# WARNING: SUPABASE_SERVICE_ROLE_KEY is server-only. NEVER expose it to client-side code or prefix with VITE_.
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini API Credentials (required for smart suggestions and concept synthesis)
GEMINI_API_KEY=
